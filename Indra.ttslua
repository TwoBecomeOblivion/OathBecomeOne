{move_to={ 0.593079, 0.1, -1.110313 }, json=[[{"GUID":"ca69d4","Name":"Custom_Tile","Transform":{"posX":24.4530773,"posY":1.58149922,"posZ":-92.49568,"rotX":2.26254861E-06,"rotY":0.02089169,"rotZ":-1.82580231E-06,"scaleX":1.83,"scaleY":1.0,"scaleZ":1.83},"Nickname":"Cell Territory","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.0,"g":0.327614635,"b":0.0659650862},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/14283916062999214154/E4EF2BFC3B5A753C46F49956DE21634371992337/","ImageSecondaryURL":"https://steamusercontent-a.akamaihd.net/ugc/11551167277027689685/2153C9A849324AF148FA8957F8B197925E53F491/","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":0,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"function onLoad()\r\n    self.createButton({\r\n        click_function = \"wincon\",\r\n        function_owner = self,\r\n        label = \"wincon\",\r\n        position = {-3,0.05,0.1125},\r\n        width = 500,\r\n        height = 100,\r\n    })\r\nend\r\n\r\nfunction wincon(obj)\r\n    winconToken = getObjectFromGUID('a83469').takeObject({\r\n        smooth = false,\r\n        rotation = {180,0,180},\r\n    })\r\n    winconToken.setPosition(obj.getPosition() + Vector(-5.445,0.9,-0.28))\r\n\r\nend","LuaScriptState":"","XmlUI":""}]]},{move_to={ 8.582071, 0.15, -3.962586 }, json=[[{"GUID":"aa8800","Name":"Custom_Token","Transform":{"posX":32.44207,"posY":1.63149929,"posZ":-95.34795,"rotX":1.91912633E-07,"rotY":0.0147090256,"rotZ":6.5047584E-07,"scaleX":0.4,"scaleY":1.0,"scaleZ":0.4},"Nickname":"Power","Description":"Cell","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.6431373,"g":1.0,"b":0.215677291},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/13638366793526084698/063D53AE2EE733B8ACC9E064FE99D15675803145/","ImageSecondaryURL":"","ImageScalar":1.0,"WidthScale":0.0,"CustomToken":{"Thickness":0.1,"MergeDistancePixels":15.0,"StandUp":false,"Stackable":false}},"LuaScript":"CONFIG = {\n    MIN_VALUE = 0,\n    MAX_VALUE = 999,\n    FONT_COLOR = {0,0,0,95},\n    FONT_SIZE = 1,\n    COLOR_HEX = \"#000000\",\n    TOOLTIP_SHOW = true,\n    VALUE = 0\n}\nINJECTED_COUNTER = true\n\n\nfunction onload(saved_data)\n    if saved_data ~= \"\" then\n        local loaded_data = JSON.decode(saved_data)\n        CONFIG = loaded_data\n    end\n    createAll()\nend\n\nfunction updateSave()\n    saved_data = JSON.encode(CONFIG)\n    self.script_state = saved_data\nend\n\nfunction createAll()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n    local scale = {x=1.5, y=1.5, z=1.5}\n    local thickness = self.getBoundsNormalized().size.y\n    if self.name == \"Custom_Tile\" then\n        thickness = thickness*2\n        scale = {0.75, 0.75, 0.75}\n    end\n    self.createButton({\n      label=tostring(CONFIG.VALUE),\n      click_function=\"add_subtract\",\n      tooltip=ttText,\n      function_owner=self,\n      position={0, thickness/2+0.05,0.08},\n      height=600,\n      width=1000,\n      alignment = 3,\n      scale=scale,\n      font_size=CONFIG.FONT_SIZE,\n      font_color=CONFIG.FONT_COLOR,\n      color={0,0,0,0}\n      })\n\n    self.createInput({\n        value = self.getName(),\n        input_function = \"editName\",\n        tooltip=ttText,\n        label = \"\",\n        function_owner = self,\n        alignment = 3,\n        position = {0,thickness/2+0.1,0},\n        width = 1,\n        height = 1,\n        font_size = CONFIG.FONT_SIZE/3,\n        scale={x=1, y=1, z=1},\n        font_color= CONFIG.FONT_COLOR,\n        color = {0,0,0,0}\n        })\n\n    setTooltips()\nend\n\nfunction editName(_obj, _string, value)\n    self.setName(value)\n    setTooltips()\nend\n\nfunction add_subtract(_obj, _color, alt_click)\n    mod = alt_click and -1 or 1\n    new_value = math.min(math.max(CONFIG.VALUE + mod, CONFIG.MIN_VALUE), CONFIG.MAX_VALUE)\n    if CONFIG.VALUE ~= new_value then\n        CONFIG.VALUE = new_value\n        updateVal()\n        updateSave()\n    end\nend\n\nfunction updateVal()\n    self.editButton({\n        index = 0,\n        label = tostring(CONFIG.VALUE)\n        })\n    setTooltips()\nend\n\nfunction setTooltips()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n\n    self.editInput({\n        index = 0,\n        value = self.getName(),\n        tooltip = ttText\n        })\n    self.editButton({\n        index = 0,\n        value = tostring(CONFIG.VALUE),\n        tooltip = ttText\n        })\nend\n","LuaScriptState":"{\"COLOR_HEX\":\"#caff8b\",\"FONT_COLOR\":[0.792,1,0.544,100],\"FONT_SIZE\":600,\"MAX_VALUE\":999,\"MIN_VALUE\":0,\"TOOLTIP_SHOW\":true,\"VALUE\":0}","XmlUI":""}]]},{move_to={ -7.283754, 0.193141, -1.166359 }, json=[[{"GUID":"22432b","Name":"Deck","Transform":{"posX":16.5762444,"posY":1.67464042,"posZ":-92.55173,"rotX":5.85296682E-08,"rotY":-3.64939042E-05,"rotZ":180.0,"scaleX":1.0,"scaleY":1.0,"scaleZ":1.0},"Nickname":"Cell Fate Deck","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.713235259,"g":0.713235259,"b":0.713235259},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":f