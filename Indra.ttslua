EVERYTHING['Anime']['Griffith'] = {image='https://steamusercontent-a.akamaihd.net/ugc/11730163576736838441/DA96C355D5314CD695021DF75226F9D8F21D3F13/', tooltip='Griffith [Berserk]', data={
{move_to={ 0.598205, 0.100003, -1.286446 }, json=[[{"GUID":"d4e530","Name":"Custom_Tile","Transform":{"posX":24.4582062,"posY":1.5815022,"posZ":-56.25645,"rotX":-1.19282959E-05,"rotY":359.993,"rotZ":2.39532983E-05,"scaleX":1.83,"scaleY":1.0,"scaleZ":1.83},"Nickname":"Griffith Territory","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.1882323,"g":0.192153871,"b":0.250977248},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/12333410645252979546/112F1B5862CF6F4670D49B409E703A420E63D3BD/","ImageSecondaryURL":"https://steamusercontent-a.akamaihd.net/ugc/17545202067243251/8E17227EEDCBBD1270E58A1EBC5DE019C626F90D/","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":0,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"function onLoad()\r\n    self.createButton({\r\n        click_function = \"wincon\",\r\n        function_owner = self,\r\n        label = \"wincon\",\r\n        position = {-3,0.05,0.1125},\r\n        width = 500,\r\n        height = 100,\r\n    })\r\nend\r\n\r\nfunction wincon(obj)\r\n    winconToken = getObjectFromGUID('a83469').takeObject({\r\n        smooth = false,\r\n        rotation = {180,0,180},\r\n    })\r\n    winconToken.setPosition(obj.getPosition() + Vector(-5.445,0.9,-0.28))\r\n\r\nend","LuaScriptState":"","XmlUI":""}]]},{move_to={ 8.551163, 0.15, -4.1092 }, json=[[{"GUID":"be7fe7","Name":"Custom_Token","Transform":{"posX":32.4111633,"posY":1.63149941,"posZ":-59.0792046,"rotX":-4.60695446E-06,"rotY":0.0109645883,"rotZ":-6.23247934E-06,"scaleX":0.4,"scaleY":1.0,"scaleZ":0.4},"Nickname":"Power","Description":"Griffith","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.831372559,"g":0.956862748,"b":1.0},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/13638366793526084698/063D53AE2EE733B8ACC9E064FE99D15675803145/","ImageSecondaryURL":"","ImageScalar":1.0,"WidthScale":0.0,"CustomToken":{"Thickness":0.1,"MergeDistancePixels":15.0,"StandUp":false,"Stackable":false}},"LuaScript":"CONFIG = {\n    MIN_VALUE = 0,\n    MAX_VALUE = 999,\n    FONT_COLOR = {0,0,0,95},\n    FONT_SIZE = 1,\n    COLOR_HEX = \"#000000\",\n    TOOLTIP_SHOW = true,\n    VALUE = 0\n}\nINJECTED_COUNTER = true\n\n\nfunction onload(saved_data)\n    if saved_data ~= \"\" then\n        local loaded_data = JSON.decode(saved_data)\n        CONFIG = loaded_data\n    end\n    createAll()\nend\n\nfunction updateSave()\n    saved_data = JSON.encode(CONFIG)\n    self.script_state = saved_data\nend\n\nfunction createAll()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n    local scale = {x=1.5, y=1.5, z=1.5}\n    local thickness = self.getBoundsNormalized().size.y\n    if self.name == \"Custom_Tile\" then\n        thickness = thickness*2\n        scale = {0.75, 0.75, 0.75}\n    end\n    self.createButton({\n      label=tostring(CONFIG.VALUE),\n      click_function=\"add_subtract\",\n      tooltip=ttText,\n      function_owner=self,\n      position={0, thickness/2+0.05,0.08},\n      height=600,\n      width=1000,\n      alignment = 3,\n      scale=scale,\n      font_size=CONFIG.FONT_SIZE,\n      font_color=CONFIG.FONT_COLOR,\n      color={0,0,0,0}\n      })\n\n    self.createInput({\n        value = self.getName(),\n        input_function = \"editName\",\n        tooltip=ttText,\n        label = \"\",\n        function_owner = self,\n        alignment = 3,\n        position = {0,thickness/2+0.1,0},\n        width = 1,\n        height = 1,\n        font_size = CONFIG.FONT_SIZE/3,\n        scale={x=1, y=1, z=1},\n        font_color= CONFIG.FONT_COLOR,\n        color = {0,0,0,0}\n        })\n\n    setTooltips()\nend\n\nfunction editName(_obj, _string, value)\n    self.setName(value)\n    setTooltips()\nend\n\nfunction add_subtract(_obj, _color, alt_click)\n    mod = alt_click and -1 or 1\n    new_value = math.min(math.max(CONFIG.VALUE + mod, CONFIG.MIN_VALUE), CONFIG.MAX_VALUE)\n    if CONFIG.VALUE ~= new_value then\n        CONFIG.VALUE = new_value\n        updateVal()\n        updateSave()\n    end\nend\n\nfunction updateVal()\n    self.editButton({\n        index = 0,\n        label = tostring(CONFIG.VALUE)\n        })\n    setTooltips()\nend\n\nfunction setTooltips()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n\n    self.editInput({\n        index = 0,\n        value = self.getName(),\n        tooltip = ttText\n        })\n    self.editButton({\n        index = 0,\n        value = tostring(CONFIG.VALUE),\n        tooltip = ttText\n        })\nend","LuaScriptState":"{\"COLOR_HEX\":\"#caff8b\",\"FONT_COLOR\":[0.906,0.976,1.00,100],\"FONT_SIZE\":600,\"MAX_VALUE\":999,\"MIN_VALUE\":0,\"TOOLTIP_SHOW\":true,\"VALUE\":0}","XmlUI":""}]]},{move_to={ -7.259544, 0.193141, -1.36975 }, json=[[{"GUID":"a9eb8d","Name":"Deck","Transform":{"posX":16.6004562,"posY":1.67464042,"posZ":-56.339756,"rotX":-1.20127588E-08,"rotY":0.000198991183,"rotZ":180.0,"scaleX":1.0,"scaleY":1.0,"scaleZ":1.0},"Nickname":"Griffith Fate Deck","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.713235259,"g":0.713235259,"b":0.713235259},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":