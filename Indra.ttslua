{move_to={ 0.624191, 0.099998, -1.196945 }, json=[[{"GUID":"f72ca9","Name":"Custom_Tile","Transform":{"posX":-163.515808,"posY":1.58149719,"posZ":-91.78531,"rotX":1.60939635E-05,"rotY":0.00447190367,"rotZ":-2.06317854E-05,"scaleX":1.83,"scaleY":1.0,"scaleZ":1.83},"Nickname":"Diaboromon Territory","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.0285453536,"g":0.040849,"b":0.17247057},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/9854178638627333857/5CB11B70499347914391F65847D1CE748BA2FD07/","ImageSecondaryURL":"https://steamusercontent-a.akamaihd.net/ugc/17545202067212761/8567443CB0124FBEE279A5D2829356CB6AF9B9BD/","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":0,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"function onLoad()\r\n    self.createButton({\r\n        click_function = \"wincon\",\r\n        function_owner = self,\r\n        label = \"wincon\",\r\n        position = {-3,0.05,0.1125},\r\n        width = 500,\r\n        height = 100,\r\n    })\r\nend\r\n\r\nfunction wincon(obj)\r\n    winconToken = getObjectFromGUID('a83469').takeObject({\r\n        smooth = false,\r\n        rotation = {180,0,180},\r\n    })\r\n    winconToken.setPosition(obj.getPosition() + Vector(-5.445,0.9,-0.28))\r\n\r\nend","LuaScriptState":"","XmlUI":""}]]},{move_to={ 8.809646, 0.15, -3.800796 }, json=[[{"GUID":"4a7432","Name":"Custom_Token","Transform":{"posX":-155.330353,"posY":1.63149929,"posZ":-94.38916,"rotX":-1.95300345E-07,"rotY":0.008570073,"rotZ":4.63198319E-07,"scaleX":0.4,"scaleY":1.0,"scaleZ":0.4},"Nickname":"Power","Description":"Diaboromon","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.407839179,"g":0.427447021,"b":0.858823538},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/13638366793526084698/063D53AE2EE733B8ACC9E064FE99D15675803145/","ImageSecondaryURL":"","ImageScalar":1.0,"WidthScale":0.0,"CustomToken":{"Thickness":0.1,"MergeDistancePixels":15.0,"StandUp":false,"Stackable":false}},"LuaScript":"CONFIG = {\n    MIN_VALUE = 0,\n    MAX_VALUE = 999,\n    FONT_COLOR = {0,0,0,95},\n    FONT_SIZE = 1,\n    COLOR_HEX = \"#000000\",\n    TOOLTIP_SHOW = true,\n    VALUE = 0\n}\nINJECTED_COUNTER = true\n\n\nfunction onload(saved_data)\n    if saved_data ~= \"\" then\n        local loaded_data = JSON.decode(saved_data)\n        CONFIG = loaded_data\n    end\n    createAll()\nend\n\nfunction updateSave()\n    saved_data = JSON.encode(CONFIG)\n    self.script_state = saved_data\nend\n\nfunction createAll()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n    local scale = {x=1.5, y=1.5, z=1.5}\n    local thickness = self.getBoundsNormalized().size.y\n    if self.name == \"Custom_Tile\" then\n        thickness = thickness*2\n        scale = {0.75, 0.75, 0.75}\n    end\n    self.createButton({\n      label=tostring(CONFIG.VALUE),\n      click_function=\"add_subtract\",\n      tooltip=ttText,\n      function_owner=self,\n      position={0, thickness/2+0.05,0.08},\n      height=600,\n      width=1000,\n      alignment = 3,\n      scale=scale,\n      font_size=CONFIG.FONT_SIZE,\n      font_color=CONFIG.FONT_COLOR,\n      color={0,0,0,0}\n      })\n\n    self.createInput({\n        value = self.getName(),\n        input_function = \"editName\",\n        tooltip=ttText,\n        label = \"\",\n        function_owner = self,\n        alignment = 3,\n        position = {0,thickness/2+0.1,0},\n        width = 1,\n        height = 1,\n        font_size = CONFIG.FONT_SIZE/3,\n        scale={x=1, y=1, z=1},\n        font_color= CONFIG.FONT_COLOR,\n        color = {0,0,0,0}\n        })\n\n    setTooltips()\nend\n\nfunction editName(_obj, _string, value)\n    self.setName(value)\n    setTooltips()\nend\n\nfunction add_subtract(_obj, _color, alt_click)\n    mod = alt_click and -1 or 1\n    new_value = math.min(math.max(CONFIG.VALUE + mod, CONFIG.MIN_VALUE), CONFIG.MAX_VALUE)\n    if CONFIG.VALUE ~= new_value then\n        CONFIG.VALUE = new_value\n        updateVal()\n        updateSave()\n    end\nend\n\nfunction updateVal()\n    self.editButton({\n        index = 0,\n        label = tostring(CONFIG.VALUE)\n        })\n    setTooltips()\nend\n\nfunction setTooltips()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n\n    self.editInput({\n        index = 0,\n        value = self.getName(),\n        tooltip = ttText\n        })\n    self.editButton({\n        index = 0,\n        value = tostring(CONFIG.VALUE),\n        tooltip = ttText\n        })\nend","LuaScriptState":"{\"COLOR_HEX\":\"#FFFFFF\",\"FONT_COLOR\":[0.45,0.469,0.894,100],\"FONT_SIZE\":600,\"MAX_VALUE\":999,\"MIN_VALUE\":0,\"TOOLTIP_SHOW\":true,\"VALUE\":0}","XmlUI":""}]]},{move_to={ -7.236129, 0.193141, -1.14508 }, json=[[{"GUID":"d9464c","Name":"Deck","Transform":{"posX":-171.376129,"posY":1.67464042,"posZ":-91.7334442,"rotX":-7.140779E-08,"rotY":9.665421E-05,"rotZ":180.0,"scaleX":1.0,"scaleY":1.0,"scaleZ":1.0},"Nickname":"Diaboromon Fate Deck","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.713235259,"g":0.713235259,"b":0.713235259},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky