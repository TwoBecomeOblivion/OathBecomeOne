{move_to={ 0.628204, 0.1, -1.212738 }, json=[[{"GUID":"432a4f","Name":"Custom_Tile","Transform":{"posX":-116.751793,"posY":1.58149922,"posZ":-91.80111,"rotX":3.4645646E-07,"rotY":0.000186769044,"rotZ":-2.040914E-07,"scaleX":1.83,"scaleY":1.0,"scaleZ":1.83},"Nickname":"Dahlia Territory","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.5803921,"g":0.3333323,"b":0.486274481},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/11720550679685042368/E0A9AB6B0AAEDCEE6189A253AED039790A07CAFC/","ImageSecondaryURL":"https://steamusercontent-a.akamaihd.net/ugc/13189059772256859700/A5FC8AB3832170FDAC1F89370F8FE4A032CDC413/","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":0,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"function onLoad()\r\n    self.createButton({\r\n        click_function = \"wincon\",\r\n        function_owner = self,\r\n        label = \"wincon\",\r\n        position = {-3,0.05,0.1125},\r\n        width = 500,\r\n        height = 100,\r\n    })\r\nend\r\n\r\nfunction wincon(obj)\r\n    winconToken = getObjectFromGUID('a83469').takeObject({\r\n        smooth = false,\r\n        rotation = {180,0,180},\r\n    })\r\n    winconToken.setPosition(obj.getPosition() + Vector(-5.445,0.9,-0.28))\r\n\r\nend","LuaScriptState":"","XmlUI":""}]]},{move_to={ 9.716477, 0.1, 2.617889 }, json=[[{"GUID":"2c3457","Name":"Custom_Tile","Transform":{"posX":-107.663521,"posY":1.58149922,"posZ":-87.97048,"rotX":1.82091764E-08,"rotY":0.006450041,"rotZ":-5.621462E-08,"scaleX":1.70045507,"scaleY":1.0,"scaleZ":1.70045507},"Nickname":"CHARM PILE","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.0348012075,"g":0.0164594911,"b":0.050522007},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/15125349190368457760/6D13357E72E9F7A3999C61985D1A807FBBCCC074/","ImageSecondaryURL":"","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":3,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"","LuaScriptState":"","XmlUI":"","AttachedSnapPoints":[{"Position":{"x":-0.0011525,"y":0.100000143,"z":-0.03851492}}]}]]},{move_to={ 8.884064, 0.15, -4.252518 }, json=[[{"GUID":"451432","Name":"Custom_Token","Transform":{"posX":-108.495934,"posY":1.63149929,"posZ":-94.84089,"rotX":1.15849978E-07,"rotY":-0.0028398647,"rotZ":-2.07424961E-07,"scaleX":0.4,"scaleY":1.0,"scaleZ":0.4},"Nickname":"Power","Description":"Dahlia","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.9529411,"g":0.7607843,"b":0.8784314},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/13638366793526084698/063D53AE2EE733B8ACC9E064FE99D15675803145/","ImageSecondaryURL":"","ImageScalar":1.0,"WidthScale":0.0,"CustomToken":{"Thickness":0.1,"MergeDistancePixels":15.0,"StandUp":false,"Stackable":false}},"LuaScript":"CONFIG = {\n    MIN_VALUE = 0,\n    MAX_VALUE = 999,\n    FONT_COLOR = {0,0,0,95},\n    FONT_SIZE = 1,\n    COLOR_HEX = \"#000000\",\n    TOOLTIP_SHOW = true,\n    VALUE = 0\n}\nINJECTED_COUNTER = true\n\n\nfunction onload(saved_data)\n    if saved_data ~= \"\" then\n        local loaded_data = JSON.decode(saved_data)\n        CONFIG = loaded_data\n    end\n    createAll()\nend\n\nfunction updateSave()\n    saved_data = JSON.encode(CONFIG)\n    self.script_state = saved_data\nend\n\nfunction createAll()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n    local scale = {x=1.5, y=1.5, z=1.5}\n    local thickness = self.getBoundsNormalized().size.y\n    if self.name == \"Custom_Tile\" then\n        thickness = thickness*2\n        scale = {0.75, 0.75, 0.75}\n    end\n    self.createButton({\n      label=tostring(CONFIG.VALUE),\n      click_function=\"add_subtract\",\n      tooltip=ttText,\n      function_owner=self,\n      position={0, thickness/2+0.05,0.08},\n      height=600,\n      width=1000,\n      alignment = 3,\n      scale=scale,\n      font_size=CONFIG.FONT_SIZE,\n      font_color=CONFIG.FONT_COLOR,\n      color={0,0,0,0}\n      })\n\n    self.createInput({\n        value = self.getName(),\n        input_function = \"editName\",\n        tooltip=ttText,\n        label = \"\",\n        function_owner = self,\n        alignment = 3,\n        position = {0,thickness/2+0.1,0},\n        width = 1,\n        height = 1,\n        font_size = CONFIG.FONT_SIZE/3,\n        scale={x=1, y=1, z=1},\n        font_color= CONFIG.FONT_COLOR,\n        color = {0,0,0,0}\n        })\n\n    setTooltips()\nend\n\nfunction editName(_obj, _string, value)\n    self.setName(value)\n    setTooltips()\nend\n\nfunction add_subtract(_obj, _color, alt_click)\n    mod = alt_click and -1 or 1\n    new_value = math.min(math.max(CONFIG.VALUE + mod, CONFIG.MIN_VALUE), CONFIG.MAX_VALUE)\n    if CONFIG.VALUE ~= new_value then\n        CONFIG.VALUE = new_value\n        updateVal()\n        updateSave()\n    end\nend\n\nfunction updateVal()\n    self.editButton({\n        index = 0,\n        label = tostring(CONFIG.VALUE)\n        })\n    setTooltips()\nend\n\nfunction setTooltips()\n    if CONFIG.TOOLTIP_SHOW then\n        ttText = self.getName().. \": \" .. CONFIG.VALUE\n    else\n        ttText = self.getName()\n    end\n\n    self.editInput({\n        index = 0,\n        value = self.getName(),\n        tooltip = ttText\n        })\n    self.editButton({\n        index = 0,\n        value = tostring(CONFIG.VALUE),\n        tooltip = ttText\n        })\nend\n","LuaScriptState":"{\"COLOR_HEX\":\"#caff8b\",\"FONT_COLOR\":[0.9765,0.8804,0.9392,100],\"FONT_SIZE\":600,\"MAX_VALUE\":999,\"MIN_VALUE\":0,\"TOOLTIP_SHOW\":true,\"VALUE\":0}","XmlUI":""}]]},{move_to={ -7.305557, 0.193141, -1.183037 }, json=[[{"GUID":"c89d16","Name":"Deck","Transform":{"posX":-124.685555,"posY":1.67464042,"posZ":-91.77141,"rotX":-1.25696275E-07,"rotY":-0.00271300343,"rotZ":180.0,"scaleX":1.0,"scaleY":1.0,"scaleZ":1.0},"Nickname":"Dahlia Fate Deck","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.713235259,"g":0.713235259,"b":0.713235259},"LayoutGroupSortIndex":0,"Value":0,"Locked":false,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":true,"Hands":false,"SidewaysCard":false,"DeckIDs":[275101,275102,275100,275103,275104,275105,275106,275107,275208,275109,275112,275111,275110,275114,275113],"CustomDeck":{"2751":{"FaceURL":"https://steamusercontent-a.akamaihd.net/ugc/13240722520616172847/BB4B3E5949AFFB5BA33B9CFDBD754FA2A86A6EF5/","BackURL":"https://steamusercontent-a.akamaihd.net/ugc/12728668817777608037/A8027AE668102973FCB23D04E3DD43B2E3987C68/","NumWidth":5,"NumHeight":3,"BackIsHidden":true,"UniqueBack":false,"Type":0},"2752":{"FaceURL":"https://steamusercontent-a.akamaihd.net/ugc/13240722520616172847/BB4B3E5949AFFB5BA33B9CFDBD754FA2A86A6EF5/","BackURL":"https://steamusercontent-a.akamaihd.net/ugc/12728668817777608037/A8027AE668102973FCB23D04E3DD43B2E3987C68/","NumWidth":5,"NumHeight":3,"BackIsHidden":true,"UniqueBack":false,"Type":0}},"LuaScript":"","LuaScriptState":"","XmlUI":"","Contained