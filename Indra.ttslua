{move_to={ 0.630554, 0.100004, -1.215046 }, json=[[{"GUID":"c0ab68","Name":"Custom_Tile","Transform":{"posX":-23.2294464,"posY":1.58150315,"posZ":-56.1850471,"rotX":-5.338679E-06,"rotY":0.0268732067,"rotZ":3.153259E-05,"scaleX":1.83,"scaleY":1.0,"scaleZ":1.83},"Nickname":"Isabella Territory","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.356857032,"g":0.356857032,"b":0.356857032},"LayoutGroupSortIndex":0,"Value":0,"Locked":true,"Grid":true,"Snap":true,"IgnoreFoW":false,"MeasureMovement":false,"DragSelectable":true,"Autoraise":true,"Sticky":true,"Tooltip":true,"GridProjection":false,"HideWhenFaceDown":false,"Hands":false,"CustomImage":{"ImageURL":"https://steamusercontent-a.akamaihd.net/ugc/13573140560250603602/AB75F141671A0620063B9D61B4BE742D6BFF7FD1/","ImageSecondaryURL":"https://steamusercontent-a.akamaihd.net/ugc/15273936341010035545/70327169707E5F785E1334DE6F2609335457282F/","ImageScalar":1.0,"WidthScale":0.0,"CustomTile":{"Type":0,"Thickness":0.1,"Stackable":false,"Stretch":true}},"LuaScript":"function onLoad()\r\n    self.createButton({\r\n        click_function = \"wincon\",\r\n        function_owner = self,\r\n        label = \"wincon\",\r\n        position = {-3,0.05,0.1125},\r\n        width = 500,\r\n        height = 100,\r\n    })\r\nend\r\n\r\nfunction wincon(obj)\r\n    winconToken = getObjectFromGUID('a83469').takeObject({\r\n        smooth = false,\r\n        rotation = {180,0,180},\r\n    })\r\n    winconToken.setPosition(obj.getPosition() + Vector(-5.445,0.9,-0.28))\r\n\r\nend","LuaScriptState":"","XmlUI":""}]]},{move_to={ 8.865365, 0.200002, 1.967508 }, json=[[{"GUID":"5b6007","Name":"Custom_Tile","Transform":{"posX":-14.9946365,"posY":1.68150079,"posZ":-53.00249,"rotX":-4.97426E-06,"rotY":0.0162774138,"rotZ":179.999954,"scaleX":1.07,"scaleY":1.0,"scaleZ":1.07},"Nickname":"DAY / NIGHT","Description":"","GMNotes":"","AltLookAngle":{"x":0.0,"y":0.0,"z":0.0},"ColorDiffuse":{"r":0.264802516,"g":0.264802516